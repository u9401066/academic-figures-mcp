# Copy this file to "env" for local development or smoke tests.
# Fill exactly one provider section with a real key.

AFM_IMAGE_PROVIDER=google
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-image-preview
AFM_MANIFEST_DIR=.academic-figures/manifests

# Metadata source (default: PubMed E-utilities)
# AFM_METADATA_SOURCE=pubmed

# Offline/demo alternative:
# AFM_METADATA_SOURCE=file
# AFM_METADATA_FILE=/absolute/path/to/papers.yaml
# AFM_SMOKE_PMID=41657234

# OpenRouter alternative:
# AFM_IMAGE_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://github.com/u9401066/academic-figures-mcp
# OPENROUTER_APP_TITLE=Academic Figures MCP
# GEMINI_MODEL=google/gemini-3.1-flash-image-preview

# OpenAI gpt-image-2 alternative:
# AFM_IMAGE_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_VISION_MODEL=gpt-5.4-mini
# OPENAI_IMAGE_SIZE=auto

# Ollama local alternative:
# AFM_IMAGE_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llava:latest
