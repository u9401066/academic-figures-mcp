# Copy this file to "env" for local development or smoke tests.
# Fill exactly one provider section with a real key.

AFM_IMAGE_PROVIDER=google
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-image-preview
AFM_MANIFEST_DIR=.academic-figures/manifests

# OpenRouter alternative:
# AFM_IMAGE_PROVIDER=openrouter
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://github.com/u9401066/academic-figures-mcp
# OPENROUTER_APP_TITLE=Academic Figures MCP
# GEMINI_MODEL=google/gemini-3.1-flash-image-preview
